{
  "name": "@unblocklabs/slack-subagent-card",
  "version": "1.0.4",
  "description": "OpenClaw plugin: Slack Block Kit status cards for sub-agent work in Slack threads.",
  "type": "module",
  "dependencies": {
    "@slack/web-api": "^7.15.0"
  },
  "devDependencies": {
    "openclaw": ">=2026.4.5"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.4.5"
    },
    "compat": {
      "pluginApi": ">=2026.4.5",
      "minGatewayVersion": ">=2026.4.5"
    },
    "build": {
      "openclawVersion": "2026.4.5",
      "pluginSdkVersion": "2026.4.5"
    }
  },
  "keywords": [
    "openclaw",
    "plugin",
    "slack",
    "subagent",
    "block-kit",
    "notifications"
  ],
  "license": "MIT",
  "author": "Unblock Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/bill492/slack-subagent-card"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.5"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "files": [
    "index.ts",
    "openclaw.plugin.json"
  ]
